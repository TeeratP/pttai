# Copy to .env and fill in.

# LLM provider used by your AgentNode LLMs / the example notebook.
OPENAI_API_KEY=

# LangSmith tracing (optional). When these are set, every graph and LLM run is
# traced automatically — no code changes needed, because the framework runs
# natively on LangChain/LangGraph. The `log` field remains a lightweight local
# fallback.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=nae
